<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Геолокация</title>
    
    <!-- Bootstrap CSS -->
    <link href="{{ url_for('static', path = 'lib/bootstrap.min.css') }}" rel="stylesheet">
    
    <!-- uPlot CSS + JS -->
    <link rel="stylesheet" href="{{ url_for('static', path = 'lib/uPlot.min.css') }}">
    <script src="{{ url_for('static', path = 'lib/uPlot.iife.min.js') }}"></script>
    
    <!-- Chart.js -->
    <script src="{{ url_for('static', path = 'lib/chart.umd.min.js') }}"></script>
    <script src="{{ url_for('static', path = 'lib/chartjs-plugin-annotation.min.js') }}"></script>
    
    <style>
        body {
            background-color: #f8f9fa;
        }
        
        /* Контейнер для uPlot с фиксированными размерами и скроллом */
        .uplot-wrapper {
            width: 800px;
            height: 150px;
            overflow-x: auto; /* Если экран меньше 800px, появится скролл */
            overflow-y: hidden;
        }
        
        /* Сам график внутри враппера */
        .uplot-chart { 
            width: 800px; 
            height: 150px; 
        }

        /* Canvas кластера должен занимать доступное место, сохраняя пропорции */
        canvas#cluster {
            width: 100% !important;
            height: auto !important;
        }
    </style>
</head>
<body>

    <div class="container py-4">
        <!-- Заголовок -->
        <header class="pb-3 mb-4 border-bottom">
            <h1 class="h3 text-secondary">Панель мониторинга</h1>
        </header>

        <div class="row g-4">
            <!-- === Левая колонка: Кластер (Chart.js) === -->
            <div class="col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="card-title mb-0">Карта кластера</h5>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center align-items-center">
                        <!-- Обертка для ограничения ширины, если нужно, но aspectRatio сделает остальное -->
                        <div style="width: 100%; max-width: 400px;">
                            <canvas id="cluster"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- === Правая колонка: Сенсоры (uPlot) === -->
            <div class="col-lg-8">
                <div class="d-flex flex-column gap-3">
                    {% for sensor in cluster.sensors %}
                    <div class="card shadow-sm">
                        <div class="card-header bg-white py-2">
                            <h6 class="mb-0 text-primary small">Сенсор №{{ sensor.id }}</h6>
                        </div>
                        <div class="card-body p-2">
                            <!-- Враппер для скролла и фиксированного размера -->
                            <div class="uplot-wrapper">
                                <div id="sensor_{{ sensor.id }}" class="uplot-chart"></div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <!-- === Логика Chart.js === -->
    <script>
        const ctx_cluster = document.getElementById('cluster').getContext('2d');
        window.clusterChart = new Chart(ctx_cluster, {
            type: 'scatter',
            data: {
                datasets: [{
                    label: 'Сенсор',
                    data: [
                        {% for sensor in cluster.sensors %}
                            {x: {{sensor.coordinates[0]}}, y: {{sensor.coordinates[1]}}},
                        {% endfor %}
                    ],
                    backgroundColor: 'rgba(54, 162, 235, 0.7)'
                },
                {
                    label: 'ИЗ',
                    data: [
                        {x: {{source.coordinates[0]}}, y: {{source.coordinates[1]}}},
                        {x: 0, y: 0}
                    ],
                    backgroundColor: 'rgba(255, 99, 132, 0.7)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true, 
                aspectRatio: 1, // <--- ДЕЛАЕТ ГРАФИК КВАДРАТНЫМ
                scales: {
                    x: { min: -5000, max: 5000, title: { display: true, text: 'X' } },
                    y: { min: -5000, max: 5000, title: { display: true, text: 'Y' } }
                },
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    </script>

    <!-- === Передаём список ID сенсоров === -->
    <script>
        window.SENSOR_IDS = [
            {% for sensor in cluster.sensors %}
                '{{ sensor.id }}'{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
    </script>

    <script src="{{ url_for('static', path = '/index.js') }}"></script>
    
    <!-- Bootstrap JS -->
    <script src="{{ url_for('static', path = 'lib/bootstrap.bundle.min.js') }}"></script>
</body>
</html>